# Telegram bot tokeni (majburiy)
BOT_TOKEN=your_telegram_bot_token_here

# Supabase Postgres ulanishi (ixtiyoriy — bo'sh bo'lsa bot DB'siz ishlaydi)
# Namuna: postgresql://postgres:PAROL@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# AI integratsiyasi (hozircha o'chirilgan).
AI_ENABLED=false
GROQ_API_KEY=

# Admin bilan aloqa (ixtiyoriy).
# ADMIN_ID — admin Telegram ID si (raqam). Foydalanuvchi xabarlari shu chatga keladi.
#   ID ni bilish uchun: @userinfobot ga /start yuboring.
# ADMIN_USERNAME — to'g'ridan-to'g'ri havola uchun (masalan: oral_detect_admin)
ADMIN_ID=
ADMIN_USERNAME=

# Health-check web server porti (Railway buni avtomatik beradi)
PORT=8080

# Log darajasi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
