# Telegram bot tokeni (majburiy)
BOT_TOKEN=your_telegram_bot_token_here

# Supabase Postgres ulanishi (ixtiyoriy — bo'sh bo'lsa bot DB'siz ishlaydi)
#
# ⚠️ MUHIM (Railway): Railway IPv6'ni qo'llamaydi, Supabase'ning to'g'ridan-to'g'ri
# ulanishi (db.xxxx.supabase.co:5432) esa faqat IPv6 — u Railway'da ISHLAMAYDI.
# Shuning uchun Supabase "Connection Pooler" (IPv4) URL'ini ishlating:
#   Supabase → Project Settings → Database → Connection string → "Connection pooling"
# Namuna (Session/Transaction pooler):
#   postgresql://postgres.<project_ref>:PAROL@aws-0-<region>.pooler.supabase.com:6543/postgres
# Eslatma: paroldagi maxsus belgilar URL-kodlanadi (masalan @ → %40).
DATABASE_URL=

# AI integratsiyasi (hozircha o'chirilgan).
AI_ENABLED=false
GROQ_API_KEY=

# Admin bilan aloqa (ixtiyoriy).
# ADMIN_ID — admin Telegram ID si (raqam). Foydalanuvchi xabarlari shu chatga keladi.
#   ID ni bilish uchun: @userinfobot ga /start yuboring.
# ADMIN_USERNAME — to'g'ridan-to'g'ri havola uchun (masalan: oral_detect_admin)
ADMIN_ID=
ADMIN_USERNAME=

# Health-check web server porti (Railway buni avtomatik beradi)
PORT=8080

# Log darajasi: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
